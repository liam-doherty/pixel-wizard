{
    "compilerOptions": {
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
        "target": "es2023",
        "module": "esnext",
        "lib": ["ES2023", "DOM"],
        "types": ["vite/client"],

        /* Bundler mode */
        "moduleResolution": "bundler",
        "noEmit": true,
        "jsx": "preserve",
        "jsxImportSource": "solid-js",
        "allowImportingTsExtensions": true
    },
    "include": ["src/**/*"],
    "exclude": ["src/**/*.test.ts"]
}
