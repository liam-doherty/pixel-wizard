{
    "mimeTypes": {
        ".js": "application/javascript",
        ".mjs": "application/javascript",
        ".wasm": "application/wasm"
    },
    "routes": [
        {
            "route": "/assets/*.js",
            "headers": {
                "Content-Type": "application/javascript; charset=utf-8"
            }
        }
    ],
    "navigationFallback": {
        "rewrite": "/index.html",
        "exclude": ["/images/*.{png,jpg,gif,svg}", "/assets/*"]
    }
}
