{
    // Visit https://aka.ms/tsconfig to read more about this file
    "compilerOptions": {
        "module": "nodenext",
        "target": "esnext",

        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,
        "composite": true,

        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "forceConsistentCasingInFileNames": true
    }
}
