{
    "compilerOptions": {
        "target": "es2023",
        "module": "esnext",
        /*"lib": ["ES2023", "DOM"],*/
        "types": ["vite/client"],
        "skipLibCheck": true,

        /* Bundler mode */
        "moduleResolution": "bundler",
        "composite": true,
        "outDir": "./dist",
        "rootDir": "./src"
    },
    "include": ["src/**/*"],
    "exclude": ["src/**/*.test.ts"]
}
