{
    "compilerOptions": {
        "strict": true,
        "target": "es2023",
        "module": "esnext",
        /*"lib": ["ES2023", "DOM"],*/
        "types": ["vite/client"],
        "skipLibCheck": true,

        /* Bundler mode */
        "moduleResolution": "bundler",
        "verbatimModuleSyntax": true,
        /*"moduleDetection": "force",*/
        "composite": true,

        /* Linting */
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "erasableSyntaxOnly": true,
        "noFallthroughCasesInSwitch": true,

        "outDir": "./dist",
        "rootDir": "./src"
    },
    "include": ["src/**/*"],
    "exclude": ["src/**/*.test.ts"]
}
